{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openproblem-atlas.org/schema/attempt.schema.json",
  "title": "OpenProblemAtlas Attempt",
  "description": "Schema for an AI or human attempt on an open problem",
  "type": "object",
  "required": [
    "attempt_id",
    "problem_id",
    "actor",
    "actor_type",
    "date",
    "method_summary",
    "outcome",
    "verification_status"
  ],
  "properties": {
    "attempt_id": {
      "type": "string",
      "pattern": "^att_[a-z0-9_-]+$",
      "description": "Unique attempt identifier"
    },
    "problem_id": {
      "type": "string",
      "description": "References a verified problem ID"
    },
    "actor": {
      "type": "string",
      "description": "Who or what made the attempt"
    },
    "actor_type": {
      "type": "string",
      "enum": ["human", "ai", "hybrid"]
    },
    "model": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "provider": { "type": "string" }
      }
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "method_summary": {
      "type": "string",
      "minLength": 10,
      "description": "Description of the approach used"
    },
    "prompt": {
      "type": "string",
      "description": "The prompt used (for AI attempts)"
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Software, libraries, hardware used"
    },
    "environment": {
      "type": "object",
      "properties": {
        "hardware": { "type": "string" },
        "runtime": { "type": "string" },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "outcome": {
      "type": "object",
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string" },
        "result_type": {
          "type": "string",
          "enum": [
            "no_progress",
            "partial_insight",
            "decomposition",
            "counterexample_candidate",
            "proof_sketch",
            "formalization",
            "literature_review",
            "computational_evidence",
            "negative_result"
          ]
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "path": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },
    "verification_status": {
      "type": "string",
      "enum": ["verified", "unverified"],
      "description": "Whether the attempt outcome has been independently verified"
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["unverified", "machine-generated", "hybrid", "not-canonical", "reproducible"]
      }
    },
    "limitations": {
      "type": "string",
      "description": "Known limitations of this attempt"
    },
    "notebook_path": {
      "type": "string",
      "description": "Path to reproducible notebook, if any"
    },
    "commit_hash": {
      "type": "string",
      "description": "Git commit hash for reproducibility"
    }
  },
  "additionalProperties": false
}
