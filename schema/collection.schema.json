{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openproblem-atlas.org/schema/collection.schema.json",
  "title": "OpenProblemAtlas Collection",
  "description": "Schema for a curated problem collection",
  "type": "object",
  "required": ["collection_id", "title", "description", "problems"],
  "properties": {
    "collection_id": {
      "type": "string",
      "pattern": "^col_[a-z0-9_-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "curator": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "problems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["problem_id"],
        "properties": {
          "problem_id": { "type": "string" },
          "note": { "type": "string" }
        }
      },
      "minItems": 1
    },
    "featured": {
      "type": "boolean",
      "description": "Whether this collection is featured on the homepage"
    }
  },
  "additionalProperties": false
}
